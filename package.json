{
  "name": "lumora-ui-workspace",
  "private": true,
  "version": "0.1.0",
  "description": "Lumora UI enterprise Tailwind design system workspace.",
  "license": "MIT",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' build",
    "changeset": "changeset",
    "check": "pnpm lint && pnpm format:check && pnpm typecheck && pnpm build && pnpm test",
    "dev": "pnpm build && pnpm --filter @lumora-ui/docs dev",
    "docs:build": "pnpm --filter @lumora-ui/docs build",
    "docs:dev": "pnpm build && pnpm --filter @lumora-ui/docs dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings=0",
    "release": "pnpm build && changeset publish",
    "release:check": "pnpm check && pnpm docs:build && pnpm pack:dry",
    "release:dry": "pnpm build && pnpm pack:dry",
    "pack:dry": "pnpm -r --filter './packages/*' pack --dry-run",
    "test:visual": "pnpm build && playwright test",
    "test:visual:update": "pnpm build && playwright test --update-snapshots",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@changesets/cli": "^2.29.0",
    "@eslint/js": "^9.0.0",
    "@next/eslint-plugin-next": "^15.5.0",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4.1.0",
    "@testing-library/react": "^16.0.0",
    "@types/jsdom": "^21.1.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vue/server-renderer": "^3.5.0",
    "axe-core": "^4.10.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "jsdom": "^27.0.0",
    "next": "^15.5.0",
    "postcss": "^8.5.0",
    "prettier": "^3.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.1.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.2.0",
    "vue": "^3.5.0"
  },
  "packageManager": "pnpm@10.26.2"
}
