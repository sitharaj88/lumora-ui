{
  "name": "@lumora-design/react",
  "version": "1.0.0",
  "description": "React wrappers for Lumora UI.",
  "license": "MIT",
  "homepage": "https://github.com/sitharaj88/lumora-ui#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sitharaj88/lumora-ui.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/sitharaj88/lumora-ui/issues"
  },
  "keywords": [
    "react",
    "tailwindcss",
    "components",
    "design-system",
    "enterprise-ui"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.tsx --format esm,cjs --dts --external react --clean",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@lumora-design/core": "workspace:^"
  },
  "peerDependencies": {
    "@lumora-design/core": "1.0.0",
    "react": "^18.0.0 || ^19.0.0"
  }
}
